# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=120
OPENAI_RETRY_COUNT=1
# Optional: path to custom CA bundle if your environment uses private certificates
# SSL_CERT_FILE=/path/to/ca-bundle.pem
# Optional: force SOX compliance mapping for every Q&A call (1=on, 0=keyword-triggered only)
SOX_ALWAYS_ON=0
# Optional: explicit path to Sarbanes-Oxley PDF
# SOX_ACT_PDF_PATH=/absolute/path/to/SARBANES_OXLEY_ACT_OF_2002.PDF

# Demo auth
DEMO_VERIFY_PIN=123456
DEMO_TOKEN_SECRET=replace-with-32-byte-hex-secret
DEMO_TOKEN_TTL_SECONDS=900

# Web app
PORT=5050
DEMO_UPLOAD_DIR=./uploads

# Google Sheets API (for gsheet_fetcher.py)
# Path to your GCP service account JSON key file
GOOGLE_SA_KEY_PATH=
# Sheet IDs (from the Google Sheet URL, between /d/ and /edit)
# Example: https://docs.google.com/spreadsheets/d/1aBcDeFgHiJkLmNoPqRsTuVwXyZ/edit
GSHEET_QCY_ID=
GSHEET_ELD_ID=
